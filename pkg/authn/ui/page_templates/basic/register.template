<!DOCTYPE html>
<html lang="en" class="h-full bg-blue-100">
  <head>
    <title>{{ .MetaTitle }} - {{ .PageTitle }}</title>
    <!-- Required meta tags -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="{{ .MetaDescription }}" />
    <meta name="author" content="{{ .MetaAuthor }}" />
    <link rel="shortcut icon" href="{{ pathjoin .ActionEndpoint "/assets/images/favicon.png" }}" type="image/png" />
    <link rel="icon" href="{{ pathjoin .ActionEndpoint "/assets/images/favicon.png" }}" type="image/png" />
    <link rel="stylesheet" href="{{ pathjoin .ActionEndpoint "/assets/line-awesome/line-awesome.css" }}" />
    <link rel="stylesheet" href="{{ pathjoin .ActionEndpoint "/assets/google-webfonts/roboto.css" }}" />
    <link rel="stylesheet" href="{{ pathjoin .ActionEndpoint "/assets/google-webfonts/montserrat.css" }}" />
    <link rel="stylesheet" href="{{ pathjoin .ActionEndpoint "/assets/css/register.css" }}" />
    {{ if eq .Data.ui_options.custom_css_required "yes" }}
      <link rel="stylesheet" href="{{ pathjoin .ActionEndpoint "/assets/css/custom.css" }}" />
    {{ end }}
  </head>

  <body class="h-full">
    <div class="app-page">
      <div class="app-content {{ if eq .Data.view "register" }}md:max-w-2xl lg:max-w-4xl{{ end }}">
        <div class="app-container">
          <div class="logo-col-box justify-center">
            {{ if .LogoURL }}
              <div>
                <img class="logo-img" src="{{ .LogoURL }}" alt="{{ .LogoDescription }}" />
              </div>
            {{ end }}
            <div>
              <h2 class="logo-col-txt">{{ .PageTitle }}</h2>
            </div>
          </div>

          {{ if .Message }}
          <div id="alerts" class="rounded-md bg-red-50 p-4">
            <div class="flex items-center">
              <div class="flex-shrink-0"><i class="las la-exclamation-triangle text-2xl text-red-600"></i></div>
              <div class="ml-3"><p class="text-sm font-medium text-red-800">{{ .Message }}</p></div>
              <div class="ml-auto pl-3">
                <div class="-mx-1.5 -my-1.5">
                  <button type="button" onclick="hideAlert(); return false;" class="app-alert-banner">
                    <span class="sr-only">{{ .Data.i18n_dismiss_action }}</span>
                    <i class="las la-times text-2xl text-red-600"></i>
                  </button>
                </div>
              </div>
            </div>
          </div>
          {{ end }}

          <div class="mt-3">
              {{ if eq .Data.view "register" }}
              <form method="POST" action="{{ pathjoin .ActionEndpoint "/register" .Data.registration_realm_name }}" class="grid grid-cols-1 gap-y-6 sm:grid-cols-2 sm:gap-x-8">
              {{ end }}

              {{ if eq .Data.view "ack" }}
              <form method="POST" action="{{ pathjoin .ActionEndpoint "/register" .Data.registration_realm_name "ack" .Data.registration_id }}">
              {{ end }}

              {{ if eq .Data.view "register" }}
                <div>
                  <label for="registrant" class="app-gen-inp-lbl">{{ .Data.i18n_username_label }}</label>
                  <div class="mt-1">
                    <input id="registrant" name="registrant" type="text" 
                      class="app-gen-inp-txt validate"
                      pattern="{{ .Data.username_validate_pattern }}"
                      title="{{ .Data.username_validate_title }}"
                      autocorrect="off" autocapitalize="off" autocomplete="username" spellcheck="false"
                      required
                      />
                  </div>
                </div>
                <div>
                  <label for="registrant_password" class="app-gen-inp-lbl">{{ .Data.i18n_password_label }}</label>
                  <div class="mt-1">
                    <input type="password" name="registrant_password" id="registrant_password"
                      class="app-gen-inp-txt validate"
                      pattern="{{ .Data.password_validate_pattern }}"
                      title="{{ .Data.password_validate_title }}"
                      autocorrect="off" autocapitalize="off" autocomplete="new-password" spellcheck="false"
                      required
                    />
                  </div>
                </div>
                <div>
                  <label for="registrant_email" class="app-gen-inp-lbl">{{ .Data.i18n_email_label }}</label>
                  <div class="mt-1">
                    <input id="registrant_email" name="registrant_email" type="email" autocomplete="email"
                      class="app-gen-inp-txt validate" 
                      autocorrect="off" autocapitalize="off" autocomplete="email" spellcheck="false"
                      required
                    />
                  </div>
                </div>
                <div>
                  <label for="first_name" class="app-gen-inp-lbl">{{ .Data.i18n_first_name_label }}</label>
                  <div class="mt-1">
                    <input type="text" name="first_name" id="first_name"
                      class="app-gen-inp-txt"
                      autocorrect="off" autocapitalize="off" autocomplete="given-name" spellcheck="false"
                    />
                  </div>
                </div>
                <div>
                  <label for="last_name" class="app-gen-inp-lbl">{{ .Data.i18n_last_name_label }}</label>
                  <div class="mt-1">
                    <input type="text" name="last_name" id="last_name"
                      class="app-gen-inp-txt"
                      autocorrect="off" autocapitalize="off" autocomplete="family-name" spellcheck="false"
                    />
                  </div>
                </div>

                {{ if .Data.require_registration_code }}
                <div>
                  <label for="registrant_code" class="app-gen-inp-lbl">{{ .Data.i18n_registration_code_label }}</label>
                  <div class="mt-1">
                    <input type="text" id="registrant_code" name="registrant_code"
                      class="app-gen-inp-txt validate"
                      autocorrect="off" autocapitalize="off" autocomplete="off" spellcheck="false"
                    />
                  </div>
                </div>
                {{ end }}

                {{ if .Data.require_accept_terms }}
                <div class="sm:col-span-2">
                  <div class="flex items-start">
                    <div class="flex-shrink-0">
                      <input id="accept_terms" name="accept_terms" type="checkbox" 
                        aria-describedby="comments-description"
                        class="focus:ring-primary-500 h-4 w-4 text-primary-600 border-gray-300 rounded"
                        required
                      />
                    </div>
                    <div class="ml-3">
                      <p class="text-base text-gray-500">
                        {{ .Data.i18n_agreement_lead_in }}
                        <a href="{{ .Data.terms_conditions_link }}" target="_blank" class="font-medium text-gray-700 underline">{{ .Data.i18n_terms_and_conditions_label }}</a>
                        {{ .Data.i18n_conjunction_and }}
                        <a href="{{ .Data.privacy_policy_link }}" target="_blank" class="font-medium text-gray-700 underline">{{ .Data.i18n_privacy_policy_label }}</a>.
                      </p>
                    </div>
                  </div>
                </div>
                {{ end }}
              {{ end }}

              {{ if eq .Data.view "registered" }}
              <div id="registered-section" class="app-txt-section">
                <p>{{ .Data.i18n_registration_welcome }}</p>
                <p>{{ .Data.i18n_things_to_keep_in_mind }}</p>
                <ol class="list-decimal pl-8">
                  <li>{{ .Data.i18n_confirmation_email_arrival }}</li>
                  <li>{{ .Data.i18n_email_support_resend }} </li>
                </ol>
              </div>
              {{ end }}

              {{ if eq .Data.view "ack" }}
              <div class="pb-4">
                <label for="registration_code" class="app-inp-lbl">{{ .Data.i18n_passcode_label }}</label>
                <div class="app-inp-box">
                  <input id="registration_code" name="registration_code" type="text"
                         class="font-['Montserrat'] app-inp-code-txt validate"
                         pattern="[A-Za-z0-9]{6,8}" maxlength="8"
                         title="{{ .Data.i18n_registration_code_length_hint }}"
                         autocorrect="off" autocapitalize="off" spellcheck="false" autocomplete="off"
                         required />
                </div>
              </div>
              {{ end }}

              {{ if eq .Data.view "ackfail" }}
              <div class="app-txt-section">
                <p>{{ .Data.i18n_general_error_unexpected }} {{ .Data.message }}.</p>
              </div>
              {{ end }}

              {{ if eq .Data.view "acked" }}

              <div class="app-txt-section">
                <p>{{ .Data.i18n_email_validation_success_message }}</p>
                <p>{{ .Data.i18n_registration_pending_explanation }}</p>
              </div>
              {{ end }}

              <div class="sm:col-span-2">
                <div class="flex gap-4 justify-end">
                  {{ if eq .Data.view "register" }}
                  <a href="{{ .ActionEndpoint }}">
                    <button type="button" name="portal" class="app-btn-sec">
                      <div><i class="las la-home"></i></div>
                      <div class="pl-1 pr-2"><span>{{ .Data.i18n_home_label }}</span></div>
                    </button>
                  </a>
                  <button type="reset" name="reset" class="app-btn-sec">
                    <div><i class="las la-redo-alt"></i></i></div>
                    <div class="pl-1 pr-2"><span>{{ .Data.i18n_clear_action }}</span></div>
                  </button>
                  <button type="submit" name="submit" class="app-btn-pri">
                    <div><i class="las la-check"></i></div>
                    <div class="pl-1 pr-2"><span>{{ .Data.i18n_submit_action }}</span></div>
                  </button>
                  {{ end }}

                  {{ if and (ne .Data.view "register") (ne .Data.view "ack") }}
                  <a href="{{ .ActionEndpoint }}">
                    <button type="button" name="portal" class="app-btn-sec">
                      <div><i class="las la-home"></i></div>
                      <div class="pl-1 pr-2"><span>{{ .Data.i18n_home_label }}</span></div>
                    </button>
                  </a>
                  {{ end }}

                  {{ if eq .Data.view "ack" }}
                  <a href="{{ .ActionEndpoint }}">
                    <button type="button" name="portal" class="app-btn-sec">
                      <div><i class="las la-home"></i></div>
                    </button>
                  </a>
                  <button type="reset" name="reset" class="app-btn-sec">
                    <div><i class="las la-redo-alt"></i></i></div>
                    <div class="pl-1 pr-2"><span>{{ .Data.i18n_clear_action }}</span></div>
                  </button>
                  <button type="submit" name="submit" class="app-btn-pri">
                    <div><i class="las la-check"></i></div>
                    <div class="pl-1 pr-2"><span>{{ .Data.i18n_submit_action }}</span></div>
                  </button>
                  {{ end }}
                </div>
              </div>

            {{ if or (eq .Data.view "register") (eq .Data.view "ack") }}
            </form>
            {{ end }}
            
          </div>
        </div>
      </div>
    </div>
    <!-- JavaScript -->
    <script src="{{ pathjoin .ActionEndpoint "/assets/js/register.js" }}"></script>
    {{ if eq .Data.ui_options.custom_js_required "yes" }}
      <script src="{{ pathjoin .ActionEndpoint "/assets/js/custom.js" }}"></script>
    {{ end }}

    <script>
    function hideAlert() {
      document.getElementById("alerts").remove();
    }

    // Check for the element and populate the field
    document.addEventListener("DOMContentLoaded", function() {
      const alertDiv = document.getElementById("alerts");
      const registeredDiv = document.getElementById("registered-section");
      const usernameFieldId = "registrant";
      const passwordFieldId = "registrant_password";
      const emailFieldId = "registrant_email";
      const firstNameFieldId = "first_name";
      const lastNameFieldId = "last_name";
      const codeFieldId = "registrant_code";

      const usernameInput = document.getElementById(usernameFieldId);
      const passwordInput = document.getElementById(passwordFieldId);
      const emailInput = document.getElementById(emailFieldId);
      const firstNameInput = document.getElementById(firstNameFieldId);
      const lastNameInput = document.getElementById(lastNameFieldId);
      const registrantCodeInput = document.getElementById(codeFieldId);

      const registrationForm = firstNameInput ? firstNameInput.closest('form') : null;

      const storedUsernameKey = "registration_username";
      const storedPasswordKey = "registration_password";
      const storedEmailKey = "registration_email";
      const storedFirstNameKey = "registration_first_name";
      const storedLastNameKey = "registration_last_name";
      const storedCodeKey = "registration_code";

      if (registeredDiv) {
        sessionStorage.removeItem(storedUsernameKey);
        sessionStorage.removeItem(storedPasswordKey);
        sessionStorage.removeItem(storedEmailKey);
        sessionStorage.removeItem(storedFirstNameKey);
        sessionStorage.removeItem(storedLastNameKey);
        sessionStorage.removeItem(storedCodeKey);
      }

      const storedUsername = sessionStorage.getItem(storedUsernameKey);
      const storedPassword = sessionStorage.getItem(storedPasswordKey);
      const storedEmail = sessionStorage.getItem(storedEmailKey);
      const storedFirstName = sessionStorage.getItem(storedFirstNameKey);
      const storedLastName = sessionStorage.getItem(storedLastNameKey);
      const storedCode = sessionStorage.getItem(storedCodeKey);

      if (registrationForm) {
        if (usernameInput && storedUsername) {
          usernameInput.value = storedUsername;
        }
        if (passwordInput && storedPassword) {
          passwordInput.value = storedPassword;
        }
        if (emailInput && storedEmail) {
          emailInput.value = storedEmail;
        }
        if (firstNameInput && storedFirstName) {
          firstNameInput.value = storedFirstName;
        }
        if (lastNameInput && storedLastName) {
          lastNameInput.value = storedLastName;
        }
        if (registrantCodeInput && storedCode) {
          registrantCodeInput.value = storedCode;
        }
      }

      if (registrationForm) {
        registrationForm.addEventListener("submit", function() {
          if (usernameInput) {
            sessionStorage.setItem(storedUsernameKey, usernameInput.value);
          }
          if (passwordInput) {
            sessionStorage.setItem(storedPasswordKey, passwordInput.value);
          }
          if (emailInput) {
            sessionStorage.setItem(storedEmailKey, emailInput.value);
          }
          if (firstNameInput) {
            sessionStorage.setItem(storedFirstNameKey, firstNameInput.value);
          }
          if (lastNameInput) {
            sessionStorage.setItem(storedLastNameKey, lastNameInput.value);
          }
          if (registrantCodeInput) {
            sessionStorage.setItem(storedCodeKey, registrantCodeInput.value);
          }
        });
        registrationForm.addEventListener("reset", function() {
          sessionStorage.removeItem(storedUsernameKey);
          sessionStorage.removeItem(storedPasswordKey);
          sessionStorage.removeItem(storedEmailKey);
          sessionStorage.removeItem(storedFirstNameKey);
          sessionStorage.removeItem(storedLastNameKey);
          sessionStorage.removeItem(storedCodeKey);
        });
      }
    });

    </script>
  </body>
</html>
